# AirTranslate Server 环境变量

# 端口 (默认 9001，避免与 AirRead 9000 冲突)
PORT=9001

# 腾讯云 COS (仅用于 EPUB 文件的 presign URL)
COS_BUCKET=your-bucket-1256643821
COS_REGION=ap-guangzhou
TENCENT_SECRET_ID=your_secret_id
TENCENT_SECRET_KEY=your_secret_key

# COS 存储前缀 (EPUB 文件存放路径前缀)
COS_PREFIX=translate/

# presign URL 有效时间 (秒，可选；不填默认 7200 = 2 小时)
COS_PRESIGN_EXPIRES_SECONDS=7200

# Worker 通信密钥 (Worker 的 .env 中也要配同样的值，不配则跳过验证)
WORKER_API_KEY=

# 注意：以下配置不再从 .env 读取，改为根目录 config.json：
# - checkin_enabled
# - checkin_points
# - initial_grant_points
# - billing_unit_chars
# - billing_unit_cost
# - latest_version
# - min_version
# - update_url
# - announcement

