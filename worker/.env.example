# 服务端 URL (Worker 通过 HTTP API 与服务端通信)
SERVER_URL=http://localhost:9001

# Worker 密钥 (与服务端 WORKER_API_KEY 一致，不配则跳过验证)
WORKER_API_KEY=

# vLLM API 地址 (OpenAI-compatible, WSL 中运行)
VLLM_API_URL=http://localhost:8000
# vLLM 中注册的模型名称
VLLM_MODEL_NAME=HY-MT1.5
# vLLM 最大上下文长度 (必须与 start_vllm.sh 中 --max-model-len 一致)
VLLM_MAX_MODEL_LEN=8192
# AI 输出 token 下限/上限 (实际会被 VLLM_MAX_MODEL_LEN/2 截断)
VLLM_MIN_OUTPUT_TOKENS=256
VLLM_MAX_OUTPUT_TOKENS=4096

# HY-MT1.5 模型本地路径 (vLLM 启动时指定)
MODEL_PATH=../models

# MyMemory 可选 email (提升免费额度到 10000词/天)
MYMEMORY_EMAIL=

# Worker 配置
POLL_INTERVAL_SEC=10
# 调度窗口大小 (同时管理的最大任务数)
SCHEDULER_WINDOW=5
# 机器翻译并发数
MACHINE_CONCURRENCY=2