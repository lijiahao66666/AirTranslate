# 服务端 URL (Worker 通过 HTTP API 与服务端通信)
SERVER_URL=http://localhost:9001

# Worker 密钥 (与服务端 WORKER_API_KEY 一致，不配则跳过验证)
WORKER_API_KEY=

# vLLM API 地址 (OpenAI-compatible, WSL 中运行)
VLLM_API_URL=http://localhost:8000
# vLLM 中注册的模型名称
VLLM_MODEL_NAME=HY-MT1.5

# HY-MT1.5 模型本地路径 (vLLM 启动时指定)
MODEL_PATH=../models

# MyMemory 可选 email (提升免费额度到 10000词/天)
MYMEMORY_EMAIL=

# Worker 配置
POLL_INTERVAL_SEC=10